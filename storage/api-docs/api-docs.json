{
    "openapi": "3.0.0",
    "info": {
        "title": "KanbanFlow API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api/v1"
        }
    ],
    "paths": {
        "/boards": {
            "get": {
                "tags": [
                    "Boards"
                ],
                "summary": "Lists all boards",
                "operationId": "079a5d2b3da6ddd10f1fe67460c0e9e7",
                "responses": {
                    "200": {
                        "description": "List of boards retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Board"
                                            }
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Boards retrieved successfully"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Boards"
                ],
                "summary": "Createa a new board",
                "operationId": "6f76efd57221ba0724e920ddb7d33c70",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BoardDTO"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Board created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                }
            }
        },
        "/boards/{id}": {
            "get": {
                "tags": [
                    "Boards"
                ],
                "summary": "Fetches a specific board",
                "operationId": "600a47f9da57f381bb382207fe0963ac",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do board",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Board found and retrieved successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Board"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Board not found"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BoardDTO": {
                "title": "BoardDTO",
                "description": "Data transfer object for board creation",
                "required": [
                    "name",
                    "theme_color",
                    "icon_key"
                ],
                "properties": {
                    "name": {
                        "type": "string",
                        "example": "Marketing Launch"
                    },
                    "description": {
                        "type": "string",
                        "example": "Q4 Campaign execution and asset tracking.",
                        "nullable": true
                    },
                    "themeColor": {
                        "type": "string",
                        "example": "#2563eb"
                    },
                    "iconKey": {
                        "type": "string",
                        "example": "megaphone"
                    }
                },
                "type": "object"
            },
            "Board": {
                "title": "Board",
                "description": "Modelo de Board no banco de dados",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Developer Sprint"
                    },
                    "description": {
                        "type": "string",
                        "nullable": true
                    },
                    "theme_color": {
                        "type": "string",
                        "example": "#2563eb"
                    },
                    "icon_key": {
                        "type": "string",
                        "example": "rocket"
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time"
                    }
                },
                "type": "object"
            }
        }
    },
    "tags": [
        {
            "name": "Boards",
            "description": "Boards"
        }
    ]
}